{
  "linear": {
    "baseUrl": ""
  },
  "models": {
    "summary": "anthropic/claude-sonnet-4",
    "extraction": "anthropic/claude-opus-4-6"
  },
  "reports": {
    "autoProcessPreviousDayOnFirstEvent": false
  },
  "extraction": {
    "rules": [
      {
        "id": "group-by-repo-folder",
        "description": "Group sessions by the repo folder name, for example /Users/you/dev/vercel/agent-observer -> agent-observer.",
        "input": "cwdBasename",
        "pattern": "^(?<repo>.+)$",
        "outputs": {
          "sessionName": "{{repo}}",
          "sessionGroup": "{{repo}}",
          "data.repo": "{{repo}}"
        }
      }
    ]
  }
}
